{
  "name": "scanmyflight",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Travel booking platform powered by TBO APIs and HDFC SmartGateway.",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "check": "npm run typecheck && npm run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.6.2",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^4.0.15"
  }
}
